# GameZone Hub Server Configuration

# The port the server will run on locally
PORT=5000

# MongoDB Connection String (Atlas or Local)
# Leave blank to automatically fall back to the fully interactive in-memory mock database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/gamezone-hub?retryWrites=true&w=majority

# JWT Token secret for user authentication
JWT_SECRET=gamezone_hub_super_secret_key_123
